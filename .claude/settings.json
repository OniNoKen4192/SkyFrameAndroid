{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "TodoWrite",
      "WebFetch",
      "WebSearch",
      "Agent",
      "Bash(*)",
      "PowerShell(*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(rm -rf ..*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf *)",
      "Bash(sudo rm*)",
      "Bash(dd if=*)",
      "Bash(mkfs*)",
      "Bash(chmod -R 777 /*)",
      "Bash(chown -R *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git push --force-with-lease *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(git clean -d*)",
      "Bash(git clean -x*)",
      "Bash(git branch -D *)",
      "Bash(git tag -d *)",
      "Bash(git tag --delete *)",
      "Bash(git push --delete *)",
      "Bash(git push origin :*)",
      "Bash(git checkout -- *)",
      "Bash(git checkout .)",
      "Bash(git restore --staged .)",
      "Bash(git restore .)",
      "Bash(git rebase --onto*)",
      "Bash(git filter-branch*)",
      "Bash(git update-ref -d*)",
      "Bash(git reflog expire*)",
      "Bash(git gc --prune=now*)",
      "Bash(:(){ :|:& };:)",
      "Bash(mv * /dev/null*)",
      "Bash(shutdown*)",
      "Bash(reboot*)",
      "Bash(halt*)",
      "Bash(init 0*)",
      "Bash(init 6*)",
      "PowerShell(Remove-Item -Recurse -Force C:\\*)",
      "PowerShell(Remove-Item -Recurse -Force /*)",
      "PowerShell(Remove-Item -Recurse -Force ~*)",
      "PowerShell(Remove-Item -Recurse -Force $HOME*)",
      "PowerShell(Remove-Item -Recurse -Force $env:USERPROFILE*)",
      "PowerShell(Remove-Item -Recurse -Force $env:WINDIR*)",
      "PowerShell(Remove-Item -Recurse -Force $env:ProgramFiles*)",
      "PowerShell(Remove-Item -Recurse -Force $env:SystemRoot*)",
      "PowerShell(Format-Volume*)",
      "PowerShell(Clear-Disk*)",
      "PowerShell(Initialize-Disk*)",
      "PowerShell(Remove-Partition*)",
      "PowerShell(Set-Disk*)",
      "PowerShell(Reset-ComputerMachinePassword*)",
      "PowerShell(Restart-Computer*)",
      "PowerShell(Stop-Computer*)",
      "PowerShell(Remove-Item HKLM:*)",
      "PowerShell(Remove-Item HKCU:*)",
      "PowerShell(Set-ItemProperty HKLM:*)",
      "PowerShell(New-ItemProperty HKLM:*)",
      "PowerShell(Remove-ItemProperty HKLM:*)",
      "PowerShell(Set-ExecutionPolicy*)",
      "PowerShell(Disable-WindowsOptionalFeature*)",
      "PowerShell(Uninstall-WindowsFeature*)",
      "PowerShell(Remove-WmiObject*)",
      "PowerShell(Stop-Process -Force -Id 0*)",
      "PowerShell(Stop-Process -Force -Id 4*)",
      "PowerShell(Get-Process | Stop-Process*)",
      "PowerShell(taskkill /F /IM explorer*)",
      "PowerShell(takeown /R *)",
      "PowerShell(icacls C:\\ /grant*)"
    ]
  }
}
